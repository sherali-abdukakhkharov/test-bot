# ─────────────────────────────────────────────────────────────
# Arab Tili Yordamchi Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Telegram Bot ─────────────────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=

# Telegram user ID of the super admin (numeric, e.g. 123456789)
# This user gets super admin privileges on first /admin command
SUPER_ADMIN_TG_ID=

# Webhook settings (only used when NODE_ENV=production)
# Must be a public HTTPS URL your server is reachable at
BOT_WEBHOOK_DOMAIN=https://your-app.fly.dev
# Random secret string to validate incoming webhook requests
BOT_WEBHOOK_SECRET=change_this_to_a_random_secret

# ── Database ─────────────────────────────────────────────────
# Full PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/arab_tili_bot

# Connection pool settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── JWT (Web Admin Panel) ─────────────────────────────────────
# Secret key used to sign JWT tokens for the web admin panel.
# Use a long, random string (e.g. openssl rand -hex 64)
JWT_SECRET=change_this_to_a_long_random_secret
# Token lifetime — keep at 8h as designed
JWT_EXPIRES_IN=8h

# ── CORS (Web Admin Panel) ────────────────────────────────────
# Comma-separated list of allowed origins for the REST API
# In development: http://localhost:5173 (Vite dev server)
# In production: your web panel domain
CORS_ORIGINS=http://localhost:5173
